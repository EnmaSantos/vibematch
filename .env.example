# Used as the OAuth/email callback origin when no request origin is available.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Auth/Postgres/Realtime
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Server-only key used by the daily movie catalog refresh. Never prefix this with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=""

# Legacy fallback if the project still uses service_role keys
SUPABASE_SERVICE_ROLE_KEY=""

# Legacy fallback if your project has not moved to publishable keys yet
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Movie data APIs, used server-side when the real API slice is added
TMDB_API_READ_KEY=""
TMDB_API_KEY=""
OMDB_API_KEY=""

# Protects /api/cron/movies; Vercel sends it as a Bearer token.
CRON_SECRET=""
